# 기본은 무료 local_extractive 요약입니다. OpenAI를 사용하려면 true와 유효한 API 키가 모두 필요합니다.
# API 사용료는 ChatGPT Plus/Codex 크레딧과 별도입니다.
# 비용을 사용하지 않으려면 USE_OPENAI_SUMMARY=false로 바꾸세요.
USE_OPENAI_SUMMARY=false
OPENAI_API_KEY=
OPENAI_SUMMARY_MODEL=gpt-5.4-mini
OPENAI_REQUEST_DELAY_MS=7000
OPENAI_MAX_RETRIES=2
OPENAI_DAILY_CALL_BUDGET=12
OPENAI_ARTICLE_TEXT_MAX_CHARS=3500
OPENAI_BODY_MAX_ITEMS=8
OPENAI_DESCRIPTION_MAX_ITEMS=6

# 최종 후보 기사에 한해 원문을 일시적으로 읽습니다. 원문은 JSON에 저장하지 않습니다.
USE_FULL_TEXT_EXTRACTION=true
ARTICLE_FETCH_TIMEOUT_MS=8000
MAX_ARTICLE_FETCH_CONCURRENCY=3
MIN_ARTICLE_TEXT_LENGTH=300
MAX_TITLE_FALLBACK_ITEMS=0
FORCE_SAVE_EMPTY=false

# 카테고리별 최대 기사 수
MAX_ITEMS_PER_CATEGORY=5
MIN_DOMESTIC_ARTICLES=8
MIN_FINAL_ARTICLES=10
MAX_FINAL_ARTICLES=15
MAX_EXTRACTION_CANDIDATES=30

# 로컬 개발에서는 후보 선별 사유를 data/debug에 저장합니다.
SAVE_DEBUG_CANDIDATES=true

# true이면 scripts/sources.js의 allowedSources 밖 출처도 포함합니다.
ALLOW_UNLISTED_SOURCES=false

# 검색 결과는 후보 발견에만 사용하며 원문 URL을 확인한 기사만 저장합니다.
ENABLE_DISCOVERY_FALLBACK=false
DISCOVERY_MAX_RESULTS_PER_QUERY=5
DISCOVERY_MAX_TOTAL_RESULTS=40
DISCOVERY_REQUIRE_ORIGINAL_URL=true
